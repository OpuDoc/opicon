---
import { getIconSvgPaintProps, iconNodeElementAttrs } from '@opudoc/opicon-shared';
import type { IconNode } from './types';

interface Props {
  iconNode: IconNode;
  size?: number | string;
  color?: string;
  strokeWidth?: number | string;
  absoluteStrokeWidth?: boolean;
  class?: string;
}

const { iconNode, size = 24, color = 'currentColor', strokeWidth = 2, absoluteStrokeWidth = false, class: className = '' } = Astro.props as Props;
const paint = getIconSvgPaintProps(iconNode, { color, strokeWidth, absoluteStrokeWidth, size });

const renderAttrs = (attrs: Record<string, string | number>) =>
  Object.entries(attrs)
    .filter(([name]) => name !== 'key')
    .map(([name, value]) => `${name}="${String(value).replace(/"/g, '&quot;')}"`)
    .join(' ');

const renderNode = (node: IconNode[number], filled: boolean): string => {
  if (node.length === 3) {
    const [tag, attrs, children] = node;
    return `<${tag} ${renderAttrs(iconNodeElementAttrs(tag, attrs, filled))}>${children.map((child) => renderNode(child, filled)).join('')}</${tag}>`;
  }
  const [tag, attrs] = node;
  return `<${tag} ${renderAttrs(iconNodeElementAttrs(tag, attrs, filled))} />`;
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  color={paint.color}
  fill={paint.fill}
  stroke={paint.stroke}
  stroke-width={paint.strokeWidth}
  class:list={['opicon', className]}
  aria-hidden="true"
  set:html={iconNode.map((node) => renderNode(node, paint.filled)).join('')}
/>
