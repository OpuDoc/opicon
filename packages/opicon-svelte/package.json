{
  "name": "@opudoc/opicon-svelte",
  "version": "0.1.6",
  "description": "An Opicon icon library package for Svelte applications.",
  "license": "ISC",
  "homepage": "https://opicon.net",
  "bugs": "https://github.com/OpuDoc/opicon/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpuDoc/opicon.git",
    "directory": "packages/opicon-svelte"
  },
  "author": "OpuDoc (https://github.com/OpuDoc)",
  "contributors": [
    "RafaelK-F (https://github.com/RafaelK-F)"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "Opicon",
    "Svelte",
    "Icons",
    "Icon",
    "SVG"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/opicon-svelte.ts",
    "./Icon.svelte": "./src/Icon.svelte",
    "./icons/*": "./src/icons/*"
  },
  "dependencies": {
    "@opudoc/opicon-shared": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "scripts": {
    "build": "node -e \"console.log('@opudoc/opicon-svelte ships Svelte source from src/')\"",
    "prepublishOnly": "node ../../scripts/build-icons.mjs"
  }
}
