{
  "name": "@opubase/opicon",
  "version": "0.1.1",
  "description": "An Opicon icon library package for web and JavaScript applications.",
  "license": "ISC",
  "homepage": "https://github.com/OpuBase/opicon",
  "bugs": "https://github.com/OpuBase/opicon/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpuBase/opicon.git",
    "directory": "packages/opicon"
  },
  "author": "OpuBase (https://github.com/OpuBase)",
  "contributors": [
    "RafaelK-F (https://github.com/RafaelK-F)"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "Opicon",
    "Icons",
    "Icon",
    "SVG",
    "JavaScript"
  ],
  "main": "dist/cjs/opicon.js",
  "module": "dist/esm/opicon.mjs",
  "types": "dist/opicon.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && rollup -c rollup.config.mjs",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.8.3"
  }
}
