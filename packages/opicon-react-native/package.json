{
  "name": "@opudoc/opicon-react-native",
  "version": "0.1.7",
  "description": "An Opicon icon library package for React Native applications.",
  "license": "ISC",
  "homepage": "https://opicon.net",
  "bugs": "https://github.com/OpuDoc/opicon/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpuDoc/opicon.git",
    "directory": "packages/opicon-react-native"
  },
  "author": "OpuDoc (https://github.com/OpuDoc)",
  "contributors": [
    "RafaelK-F (https://github.com/RafaelK-F)"
  ],
  "publishConfig": {
