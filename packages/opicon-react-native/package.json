  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/react": "^18.2.37",
    "react": "^18.2.0",
    "react-native-svg": "^15.11.0",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.2.3",
